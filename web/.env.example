# === Supabase (Settings -> API) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
# JANGAN expose ke browser. Hanya dipakai di API routes (server-side).
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# === Keamanan agen (HMAC) ===
# Master secret untuk menurunkan agent_secret tiap peserta (TDD §11).
# Buat string acak panjang, mis: openssl rand -hex 32
AGENT_HMAC_SECRET=ganti-dengan-string-acak-panjang

# === Admin (v0.1 sederhana) ===
# Password admin untuk halaman /admin (v0.2 pindah ke Supabase Auth).
ADMIN_PASSWORD=ganti-password-admin
